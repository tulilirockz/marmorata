[Unit]
Description=Syncthing container

[Service]
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target

[Container]
AutoUpdate=registry
ContainerName=syncthing
Environment=PGID=0
Environment=PUID=0
Image=docker.io/syncthing/syncthing:latest
PublishPort=22000:22000/tcp
PublishPort=22000:22000/udp
PublishPort=9384:8384/tcp
PublishPort=9384:8384/udp
Volume=%h/srv/media/:/srv/media:z
Volume=%h/srv/syncthing-config:/var/syncthing:Z
Volume=%h/srv/syncthing-data/:/srv/syncthing-data:z
